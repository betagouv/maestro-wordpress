# Cache zone for FastCGI
fastcgi_cache_path /var/cache/nginx levels=1:2 keys_zone=wordpress:100m inactive=24h use_temp_path=off;

server {
  server_name localhost;
  listen 80;

  charset utf-8;

  # Gzip compression
  gzip on;
  gzip_vary on;
  gzip_min_length 1024;
  gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml;

  # FastCGI optimization
  fastcgi_buffering on;
  fastcgi_buffers 16 16k;
  fastcgi_buffer_size 32k;
  fastcgi_busy_buffers_size 64k;
  fastcgi_temp_file_write_size 64k;

  # Timeouts
  fastcgi_connect_timeout 60s;
  fastcgi_send_timeout 300s;
  fastcgi_read_timeout 300s;

  error_log  /var/log/nginx/error.log;
  access_log /var/log/nginx/access.log;

  root /app/web;
  index index.php;

  # Security headers
  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header X-XSS-Protection "1; mode=block" always;

  location / {
    try_files $uri $uri/ /index.php?$args;
  }

  # Cache static assets aggressively
  location ~* ^.+\.(js|css|jpe?g|gif|ico|png|svg|woff|woff2|ttf|eot)$ {
    expires 30d;
    add_header Cache-Control "public, immutable";
  }

  # Don't cache admin and login areas
  location ~ ^/(wp-admin|wp-login\.php) {
    fastcgi_cache off;
    try_files $uri =404;
    fastcgi_split_path_info ^(.+\.php)(/.+)$;
    fastcgi_pass web:9000;
    fastcgi_index index.php;
    include fastcgi_params;
    fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    fastcgi_param PATH_INFO $fastcgi_path_info;
  }

  location ~ \.php$ {
    try_files $uri =404;
    fastcgi_split_path_info ^(.+\.php)(/.+)$;
    fastcgi_pass web:9000;
    fastcgi_index index.php;
    include fastcgi_params;
    fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    fastcgi_param PATH_INFO $fastcgi_path_info;

    # Set FastCGI cache key for dynamic content
    set $skip_cache 0;

    # Skip cache for non-GET requests
    if ($request_method != GET) {
      set $skip_cache 1;
    }

    # Skip cache for logged-in users
    if ($http_cookie ~* "wordpress_logged_in|wp-settings") {
      set $skip_cache 1;
    }

    # Skip cache for query strings (except pagination)
    if ($args ~ "^(?!.*paged).*") {
      set $skip_cache 1;
    }

    fastcgi_cache wordpress;
    fastcgi_cache_key "$scheme$request_method$host$request_uri";
    fastcgi_cache_use_stale error timeout updating http_500 http_503;
    fastcgi_cache_bypass $skip_cache;
    fastcgi_no_cache $skip_cache;
    add_header X-Cache-Status $upstream_cache_status;
  }

  # Deny access to sensitive files
  location ~ /\.env {
    deny all;
  }
}

